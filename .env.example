# Vercel KV / Upstash Redis credentials.
# In Vercel these are set automatically when you connect a KV/Upstash store.
# For local development or running the migration script, copy this file to
# .env.local and fill in the values from the Vercel/Upstash dashboard.

KV_REST_API_URL=
KV_REST_API_TOKEN=

# The Upstash Marketplace integration sometimes uses these names instead;
# either pair works (the app checks both).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Anthropic API key for the experimental photo-grading feature (foto-grade.html).
# Create one at https://console.anthropic.com -> API Keys. Used ONLY server-side
# by api/photo-analyze.mjs; never exposed to the browser.
ANTHROPIC_API_KEY=
